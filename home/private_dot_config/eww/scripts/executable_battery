#!/usr/bin/env bash

bat=/sys/class/power_supply/BAT0/
per="$(cat "$bat/capacity")"

icon() {

[ $(cat "$bat/status") = Charging ] && echo "’ā¦" && exit

if [ "$per" -gt "90" ]; then
	icon="’ēĆ"
elif [ "$per" -gt "80" ]; then
	icon="’ēü"
elif [ "$per" -gt "70" ]; then
	icon="’ēü"
elif [ "$per" -gt "60" ]; then
	icon="’ēé"
elif [ "$per" -gt "50" ]; then
	icon="’ēā"
elif [ "$per" -gt "40" ]; then
	icon="’ēā"
elif [ "$per" -gt "30" ]; then
	icon="’ēā"
elif [ "$per" -gt "20" ]; then
	icon="’ēä"
elif [ "$per" -gt "10" ]; then
	icon="’ēä"
	notify-send -u critical "Battery Low" "Connect Charger"
elif [ "$per" -gt "0" ]; then
	icon="’ēä"
	notify-send -u critical "Battery Low" "Connect Charger"
else
        echo ’¢Ź && exit
fi
echo "$icon"
}

percent() {
echo $per
}

[ "$1" = "icon" ] && icon && exit
[ "$1" = "percent" ] && percent && exit
exit
